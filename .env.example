# Tokani TripFlow - Environment Variables
# Copy this file to .env for local development
# In production (Replit), set these via Replit Secrets (Tools → Secrets)

# ==============================================================================
# DEMO LOGIN CREDENTIALS (Island Travel Technologies)
# ==============================================================================
# These credentials are used for the demo login feature
# The password is hashed with bcrypt before storage (10 rounds)

DEMO_COMPANY_CODE=itt001
DEMO_EMAIL=desmond.bale@islandtraveltech.com
DEMO_PASSWORD=itt1235*

# ==============================================================================
# DATABASE (Auto-configured by Replit)
# ==============================================================================
# These are automatically set by Replit when you create a PostgreSQL database
# Do NOT manually set these - they're managed by the platform

# DATABASE_URL=postgresql://...
# PGHOST=...
# PGPORT=...
# PGDATABASE=...
# PGUSER=...
# PGPASSWORD=...

# ==============================================================================
# SESSION MANAGEMENT (Auto-configured)
# ==============================================================================
# Automatically generated by the application on first run

# SESSION_SECRET=...

# ==============================================================================
# OBJECT STORAGE (Auto-configured)
# ==============================================================================
# Set by Replit when object storage is enabled

# DEFAULT_OBJECT_STORAGE_BUCKET_ID=...
# PUBLIC_OBJECT_SEARCH_PATHS=...
# PRIVATE_OBJECT_DIR=...

# ==============================================================================
# OPTIONAL: EXTERNAL SERVICES
# ==============================================================================
# Add these if you integrate third-party services

# Amadeus API (for flight/hotel data - future enhancement)
# AMADEUS_API_KEY=...
# AMADEUS_API_SECRET=...

# SendGrid (for email notifications - future enhancement)
# SENDGRID_API_KEY=...

# ==============================================================================
# NOTES
# ==============================================================================
# 1. Never commit .env to version control (.env is in .gitignore)
# 2. This file (.env.example) is safe to commit as a template
# 3. For production, use Replit Secrets instead of .env file
# 4. Restart the application after changing environment variables
